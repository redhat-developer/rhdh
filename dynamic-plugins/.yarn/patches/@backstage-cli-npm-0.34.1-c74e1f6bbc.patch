+{"version":3,"file":"packageRole.cjs.js","sources":["../../../../src/modules/migrate/commands/packageRole.ts"],"sourcesContent":["/*\n * Copyright 2020 The Backstage Authors\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\nimport fs from 'fs-extra';\nimport { resolve as resolvePath } from 'path';\nimport { getPackages } from '@manypkg/get-packages';\nimport { PackageRoles } from '@backstage/cli-node';\nimport { paths } from '../../../lib/paths';\n\nexport default async () => {\n  const { packages } = await getPackages(paths.targetDir);\n\n  await Promise.all(\n    packages.map(async ({ dir, packageJson: pkg }) => {\n      const { name } = pkg;\n      const existingRole = PackageRoles.getRoleFromPackage(pkg);\n      if (existingRole) {\n        return;\n      }\n\n      const detectedRole = PackageRoles.detectRoleFromPackage(pkg);\n      if (!detectedRole) {\n        console.error(`No role detected for package ${name}`);\n        return;\n      }\n\n      console.log(`Detected package role of ${name} as ${detectedRole}`);\n\n      let newPkg = pkg as any;\n\n      const pkgKeys = Object.keys(pkg);\n      if (pkgKeys.includes('backstage')) {\n        newPkg.backstage = {\n          ...newPkg.backstage,\n          role: detectedRole,\n        };\n      } else {\n        // We insert the backstage field after one of these fields, otherwise at the end\n        const index =\n          Math.max(\n            pkgKeys.indexOf('version'),\n            pkgKeys.indexOf('private'),\n            pkgKeys.indexOf('publishConfig'),\n          ) + 1 || pkgKeys.length;\n\n        const pkgEntries = Object.entries(pkg);\n        pkgEntries.splice(index, 0, ['backstage', { role: detectedRole }]);\n        newPkg = Object.fromEntries(pkgEntries);\n      }\n\n      await fs.writeJson(resolvePath(dir, 'package.json'), newPkg, {\n        spaces: 2,\n      });\n    }),\n  );\n};\n"],"names":["getPackages","paths","PackageRoles","fs","resolvePath"],"mappings":";;;;;;;;;;;;;;AAsBA,kBAAe,YAAY;AACzB,EAAA,MAAM,EAAE,QAAA,EAAS,GAAI,MAAMA,uBAAA,CAAYC,YAAM,SAAS,CAAA;AAEtD,EAAA,MAAM,OAAA,CAAQ,GAAA;AAAA,IACZ,SAAS,GAAA,CAAI,OAAO,EAAE,GAAA,EAAK,WAAA,EAAa,KAAI,KAAM;AAChD,MAAA,MAAM,EAAE,MAAK,GAAI,GAAA;AACjB,MAAA,MAAM,YAAA,GAAeC,oBAAA,CAAa,kBAAA,CAAmB,GAAG,CAAA;AACxD,MAAA,IAAI,YAAA,EAAc;AAChB,QAAA;AAAA,MACF;AAEA,MAAA,MAAM,YAAA,GAAeA,oBAAA,CAAa,qBAAA,CAAsB,GAAG,CAAA;AAC3D,MAAA,IAAI,CAAC,YAAA,EAAc;AACjB,QAAA,OAAA,CAAQ,KAAA,CAAM,CAAA,6BAAA,EAAgC,IAAI,CAAA,CAAE,CAAA;AACpD,QAAA;AAAA,MACF;AAEA,MAAA,OAAA,CAAQ,GAAA,CAAI,CAAA,yBAAA,EAA4B,IAAI,CAAA,IAAA,EAAO,YAAY,CAAA,CAAE,CAAA;AAEjE,MAAA,IAAI,MAAA,GAAS,GAAA;AAEb,MAAA,MAAM,OAAA,GAAU,MAAA,CAAO,IAAA,CAAK,GAAG,CAAA;AAC/B,MAAA,IAAI,OAAA,CAAQ,QAAA,CAAS,WAAW,CAAA,EAAG;AACjC,QAAA,MAAA,CAAO,SAAA,GAAY;AAAA,UACjB,GAAG,MAAA,CAAO,SAAA;AAAA,UACV,IAAA,EAAM;AAAA,SACR;AAAA,MACF,CAAA,MAAO;AAEL,QAAA,MAAM,QACJ,IAAA,CAAK,GAAA;AAAA,UACH,OAAA,CAAQ,QAAQ,SAAS,CAAA;AAAA,UACzB,OAAA,CAAQ,QAAQ,SAAS,CAAA;AAAA,UACzB,OAAA,CAAQ,QAAQ,eAAe;AAAA,SACjC,GAAI,KAAK,OAAA,CAAQ,MAAA;AAEnB,QAAA,MAAM,UAAA,GAAa,MAAA,CAAO,OAAA,CAAQ,GAAG,CAAA;AACrC,QAAA,UAAA,CAAW,MAAA,CAAO,OAAO,CAAA,EAAG,CAAC,aAAa,EAAE,IAAA,EAAM,YAAA,EAAc,CAAC,CAAA;AACjE,QAAA,MAAA,GAAS,MAAA,CAAO,YAAY,UAAU,CAAA;AAAA,MACxC;AAEA,MAAA,MAAMC,oBAAG,SAAA,CAAUC,YAAA,CAAY,GAAA,EAAK,cAAc,GAAG,MAAA,EAAQ;AAAA,QAC3D,MAAA,EAAQ;AAAA,OACT,CAAA;AAAA,IACH,CAAC;AAAA,GACH;AACF,CAAA;;;;"}
