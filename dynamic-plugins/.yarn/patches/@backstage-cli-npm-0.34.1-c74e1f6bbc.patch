+{"version":3,"file":"clean.cjs.js","sources":["../../../../../src/modules/maintenance/commands/repo/clean.ts"],"sourcesContent":["/*\n * Copyright 2020 The Backstage Authors\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\nimport { execFile as execFileCb } from 'child_process';\nimport fs from 'fs-extra';\nimport { resolve as resolvePath } from 'path';\nimport { promisify } from 'util';\nimport { PackageGraph } from '@backstage/cli-node';\nimport { paths } from '../../../../lib/paths';\n\nconst execFile = promisify(execFileCb);\n\nexport async function command(): Promise<void> {\n  const packages = await PackageGraph.listTargetPackages();\n\n  await fs.remove(paths.resolveTargetRoot('dist'));\n  await fs.remove(paths.resolveTargetRoot('dist-types'));\n  await fs.remove(paths.resolveTargetRoot('coverage'));\n\n  await Promise.all(\n    Array.from(Array(10), async () => {\n      while (packages.length > 0) {\n        const pkg = packages.pop()!;\n        const cleanScript = pkg.packageJson.scripts?.clean;\n\n        if (\n          cleanScript === 'backstage-cli clean' ||\n          cleanScript === 'backstage-cli package clean'\n        ) {\n          await fs.remove(resolvePath(pkg.dir, 'dist'));\n          await fs.remove(resolvePath(pkg.dir, 'dist-types'));\n          await fs.remove(resolvePath(pkg.dir, 'coverage'));\n        } else if (cleanScript) {\n          const result = await execFile('yarn', ['run', 'clean'], {\n            cwd: pkg.dir,\n            shell: true,\n          });\n          process.stdout.write(result.stdout);\n          process.stderr.write(result.stderr);\n        }\n      }\n    }),\n  );\n}\n"],"names":["promisify","execFileCb","PackageGraph","fs","paths","resolvePath"],"mappings":";;;;;;;;;;;;;AAuBA,MAAM,QAAA,GAAWA,eAAUC,sBAAU,CAAA;AAErC,eAAsB,OAAA,GAAyB;AAC7C,EAAA,MAAM,QAAA,GAAW,MAAMC,oBAAA,CAAa,kBAAA,EAAmB;AAEvD,EAAA,MAAMC,mBAAA,CAAG,MAAA,CAAOC,WAAA,CAAM,iBAAA,CAAkB,MAAM,CAAC,CAAA;AAC/C,EAAA,MAAMD,mBAAA,CAAG,MAAA,CAAOC,WAAA,CAAM,iBAAA,CAAkB,YAAY,CAAC,CAAA;AACrD,EAAA,MAAMD,mBAAA,CAAG,MAAA,CAAOC,WAAA,CAAM,iBAAA,CAAkB,UAAU,CAAC,CAAA;AAEnD,EAAA,MAAM,OAAA,CAAQ,GAAA;AAAA,IACZ,KAAA,CAAM,IAAA,CAAK,KAAA,CAAM,EAAE,GAAG,YAAY;AAChC,MAAA,OAAO,QAAA,CAAS,SAAS,CAAA,EAAG;AAC1B,QAAA,MAAM,GAAA,GAAM,SAAS,GAAA,EAAI;AACzB,QAAA,MAAM,WAAA,GAAc,GAAA,CAAI,WAAA,CAAY,OAAA,EAAS,KAAA;AAE7C,QAAA,IACE,WAAA,KAAgB,qBAAA,IAChB,WAAA,KAAgB,6BAAA,EAChB;AACA,UAAA,MAAMD,oBAAG,MAAA,CAAOE,YAAA,CAAY,GAAA,CAAI,GAAA,EAAK,MAAM,CAAC,CAAA;AAC5C,UAAA,MAAMF,oBAAG,MAAA,CAAOE,YAAA,CAAY,GAAA,CAAI,GAAA,EAAK,YAAY,CAAC,CAAA;AAClD,UAAA,MAAMF,oBAAG,MAAA,CAAOE,YAAA,CAAY,GAAA,CAAI,GAAA,EAAK,UAAU,CAAC,CAAA;AAAA,QAClD,WAAW,WAAA,EAAa;AACtB,UAAA,MAAM,SAAS,MAAM,QAAA,CAAS,QAAQ,CAAC,KAAA,EAAO,OAAO,CAAA,EAAG;AAAA,YACtD,KAAK,GAAA,CAAI,GAAA;AAAA,YACT,KAAA,EAAO;AAAA,WACR,CAAA;AACD,UAAA,OAAA,CAAQ,MAAA,CAAO,KAAA,CAAM,MAAA,CAAO,MAAM,CAAA;AAClC,UAAA,OAAA,CAAQ,MAAA,CAAO,KAAA,CAAM,MAAA,CAAO,MAAM,CAAA;AAAA,QACpC;AAAA,MACF;AAAA,IACF,CAAC;AAAA,GACH;AACF;;;;"}
