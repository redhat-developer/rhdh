aulting to watch mode',\n      execute: async ({ args }) => {\n        const command = new Command();\n\n        command.allowUnknownOption(true);\n        command.helpOption(', --backstage-cli-help');\n        command.action(\n          lazy(() => import('./commands/package/test'), 'default'),\n        );\n        await command.parseAsync(args, { from: 'user' });\n      },\n    });\n  },\n});\n"],"names":["createCliPlugin","Command","lazy"],"mappings":";;;;;;;;AAmBA,YAAeA,uBAAA,CAAgB;AAAA,EAC7B,QAAA,EAAU,MAAA;AAAA,EACV,IAAA,EAAM,OAAM,GAAA,KAAO;AACjB,IAAA,GAAA,CAAI,UAAA,CAAW;AAAA,MACb,IAAA,EAAM,CAAC,MAAA,EAAQ,MAAM,CAAA;AAAA,MACrB,WAAA,EACE,8DAAA;AAAA,MACF,OAAA,EAAS,OAAO,EAAE,IAAA,EAAK,KAAM;AAC3B,QAAA,MAAM,OAAA,GAAU,IAAIC,iBAAA,EAAQ;AAC5B,QAAA,OAAA,CAAQ,mBAAmB,IAAI,CAAA;AAC/B,QAAA,OAAA,CAAQ,MAAA;AAAA,UACN,eAAA;AAAA,UACA;AAAA,SACF;AACA,QAAA,OAAA,CAAQ,MAAA,CAAO,kBAAkB,wBAAwB,CAAA;AACzD,QAAA,OAAA,CAAQ,MAAA;AAAA,UACN,0BAAA;AAAA,UACA;AAAA,SACF;AACA,QAAA,OAAA,CAAQ,MAAA;AAAA,UACN,aAAA;AAAA,UACA;AAAA,SACF;AACA,QAAA,OAAA,CAAQ,OAAOC,SAAA,CAAK,MAAM,OAAO,6BAAsB,CAAA,EAAG,SAAS,CAAC,CAAA;AACpE,QAAA,MAAM,QAAQ,UAAA,CAAW,IAAA,EAAM,EAAE,IAAA,EAAM,QAAQ,CAAA;AAAA,MACjD;AAAA,KACD,CAAA;AAED,IAAA,GAAA,CAAI,UAAA,CAAW;AAAA,MACb,IAAA,EAAM,CAAC,SAAA,EAAW,MAAM,CAAA;AAAA,MACxB,WAAA,EACE,8DAAA;AAAA,MACF,OAAA,EAAS,OAAO,EAAE,IAAA,EAAK,KAAM;AAC3B,QAAA,MAAM,OAAA,GAAU,IAAID,iBAAA,EAAQ;AAE5B,QAAA,OAAA,CAAQ,mBAAmB,IAAI,CAAA;AAC/B,QAAA,OAAA,CAAQ,WAAW,wBAAwB,CAAA;AAC3C,QAAA,OAAA,CAAQ,MAAA;AAAA,UACNC,SAAA,CAAK,MAAM,OAAO,gCAAyB,GAAG,SAAS;AAAA,SACzD;AACA,QAAA,MAAM,QAAQ,UAAA,CAAW,IAAA,EAAM,EAAE,IAAA,EAAM,QAAQ,CAAA;AAAA,MACjD;AAAA,KACD,CAAA;AAAA,EACH;AACF,CAAC,CAAA;;;;"}
