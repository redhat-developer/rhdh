+{"version":3,"file":"run.cjs.js","sources":["../../src/lib/run.ts"],"sourcesContent":["/*\n * Copyright 2020 The Backstage Authors\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\nimport {\n  SpawnOptions,\n  spawn,\n  ChildProcess,\n  execFile as execFileCb,\n} from 'child_process';\nimport { ExitCodeError } from './errors';\nimport { promisify } from 'util';\nimport { assertError, ForwardedError } from '@backstage/errors';\n\nexport const execFile = promisify(execFileCb);\n\ntype LogFunc = (data: Buffer) => void;\n\ntype SpawnOptionsPartialEnv = Omit<SpawnOptions, 'env'> & {\n  env?: Partial<NodeJS.ProcessEnv>;\n  // Pipe stdout to this log function\n  stdoutLogFunc?: LogFunc;\n  // Pipe stderr to this log function\n  stderrLogFunc?: LogFunc;\n};\n\n// Runs a child command, returning a promise that is only resolved if the child exits with code 0.\nexport async function run(\n  name: string,\n  args: string[] = [],\n  options: SpawnOptionsPartialEnv = {},\n) {\n  const { stdoutLogFunc, stderrLogFunc } = options;\n  const env: NodeJS.ProcessEnv = {\n    ...process.env,\n    FORCE_COLOR: 'true',\n    ...(options.env ?? {}),\n  };\n\n  const stdio = [\n    'inherit',\n    stdoutLogFunc ? 'pipe' : 'inherit',\n    stderrLogFunc ? 'pipe' : 'inherit',\n  ] as ('inherit' | 'pipe')[];\n\n  const child = spawn(name, args, {\n    stdio,\n    shell: true,\n    ...options,\n    env,\n  });\n\n  if (stdoutLogFunc && child.stdout) {\n    child.stdout.on('data', stdoutLogFunc);\n  }\n  if (stderrLogFunc && child.stderr) {\n    child.stderr.on('data', stderrLogFunc);\n  }\n\n  await waitForExit(child, name);\n}\n\nexport async function runPlain(cmd: string, ...args: string[]) {\n  try {\n    const { stdout } = await execFile(cmd, args, { shell: true });\n    return stdout.trim();\n  } catch (error) {\n    assertError(error);\n    if ('stderr' in error) {\n      process.stderr.write(error.stderr as Buffer);\n    }\n    if (typeof error.code === 'number') {\n      throw new ExitCodeError(error.code, [cmd, ...args].join(' '));\n    }\n    throw new ForwardedError('Unknown execution error', error);\n  }\n}\n\nexport async function runCheck(cmd: string, ...args: string[]) {\n  try {\n    await execFile(cmd, args, { shell: true });\n    return true;\n  } catch (error) {\n    return false;\n  }\n}\n\nexport async function waitForExit(\n  child: ChildProcess & { exitCode: number | null },\n  name?: string,\n): Promise<void> {\n  if (typeof child.exitCode === 'number') {\n    if (child.exitCode) {\n      throw new ExitCodeError(child.exitCode, name);\n    }\n    return;\n  }\n\n  await new Promise<void>((resolve, reject) => {\n    child.once('error', error => reject(error));\n    child.once('exit', code => {\n      if (code) {\n        reject(new ExitCodeError(code, name));\n      } else {\n        resolve();\n      }\n    });\n  });\n}\n"],"names":["promisify","execFileCb","spawn","assertError","ExitCodeError","ForwardedError"],"mappings":";;;;;;;AA0BO,MAAM,QAAA,GAAWA,eAAUC,sBAAU;AAa5C,eAAsB,IACpB,IAAA,EACA,IAAA,GAAiB,EAAC,EAClB,OAAA,GAAkC,EAAC,EACnC;AACA,EAAA,MAAM,EAAE,aAAA,EAAe,aAAA,EAAc,GAAI,OAAA;AACzC,EAAA,MAAM,GAAA,GAAyB;AAAA,IAC7B,GAAG,OAAA,CAAQ,GAAA;AAAA,IACX,WAAA,EAAa,MAAA;AAAA,IACb,GAAI,OAAA,CAAQ,GAAA,IAAO;AAAC,GACtB;AAEA,EAAA,MAAM,KAAA,GAAQ;AAAA,IACZ,SAAA;AAAA,IACA,gBAAgB,MAAA,GAAS,SAAA;AAAA,IACzB,gBAAgB,MAAA,GAAS;AAAA,GAC3B;AAEA,EAAA,MAAM,KAAA,GAAQC,mBAAA,CAAM,IAAA,EAAM,IAAA,EAAM;AAAA,IAC9B,KAAA;AAAA,IACA,KAAA,EAAO,IAAA;AAAA,IACP,GAAG,OAAA;AAAA,IACH;AAAA,GACD,CAAA;AAED,EAAA,IAAI,aAAA,IAAiB,MAAM,MAAA,EAAQ;AACjC,IAAA,KAAA,CAAM,MAAA,CAAO,EAAA,CAAG,MAAA,EAAQ,aAAa,CAAA;AAAA,EACvC;AACA,EAAA,IAAI,aAAA,IAAiB,MAAM,MAAA,EAAQ;AACjC,IAAA,KAAA,CAAM,MAAA,CAAO,EAAA,CAAG,MAAA,EAAQ,aAAa,CAAA;AAAA,EACvC;AAEA,EAAA,MAAM,WAAA,CAAY,OAAO,IAAI,CAAA;AAC/B;AAEA,eAAsB,QAAA,CAAS,QAAgB,IAAA,EAAgB;AAC7D,EAAA,IAAI;AACF,IAAA,MAAM,EAAE,MAAA,EAAO,GAAI,MAAM,QAAA,CAAS,KAAK,IAAA,EAAM,EAAE,KAAA,EAAO,IAAA,EAAM,CAAA;AAC5D,IAAA,OAAO,OAAO,IAAA,EAAK;AAAA,EACrB,SAAS,KAAA,EAAO;AACd,IAAAC,oBAAA,CAAY,KAAK,CAAA;AACjB,IAAA,IAAI,YAAY,KAAA,EAAO;AACrB,MAAA,OAAA,CAAQ,MAAA,CAAO,KAAA,CAAM,KAAA,CAAM,MAAgB,CAAA;AAAA,IAC7C;AACA,IAAA,IAAI,OAAO,KAAA,CAAM,IAAA,KAAS,QAAA,EAAU;AAClC,MAAA,MAAM,IAAIC,oBAAA,CAAc,KAAA,CAAM,IAAA,EAAM,CAAC,GAAA,EAAK,GAAG,IAAI,CAAA,CAAE,IAAA,CAAK,GAAG,CAAC,CAAA;AAAA,IAC9D;AACA,IAAA,MAAM,IAAIC,uBAAA,CAAe,yBAAA,EAA2B,KAAK,CAAA;AAAA,EAC3D;AACF;AAEA,eAAsB,QAAA,CAAS,QAAgB,IAAA,EAAgB;AAC7D,EAAA,IAAI;AACF,IAAA,MAAM,SAAS,GAAA,EAAK,IAAA,EAAM,EAAE,KAAA,EAAO,MAAM,CAAA;AACzC,IAAA,OAAO,IAAA;AAAA,EACT,SAAS,KAAA,EAAO;AACd,IAAA,OAAO,KAAA;AAAA,EACT;AACF;AAEA,eAAsB,WAAA,CACpB,OACA,IAAA,EACe;AACf,EAAA,IAAI,OAAO,KAAA,CAAM,QAAA,KAAa,QAAA,EAAU;AACtC,IAAA,IAAI,MAAM,QAAA,EAAU;AAClB,MAAA,MAAM,IAAID,oBAAA,CAAc,KAAA,CAAM,QAAA,EAAU,IAAI,CAAA;AAAA,IAC9C;AACA,IAAA;AAAA,EACF;AAEA,EAAA,MAAM,IAAI,OAAA,CAAc,CAAC,OAAA,EAAS,MAAA,KAAW;AAC3C,IAAA,KAAA,CAAM,IAAA,CAAK,OAAA,EAAS,CAAA,KAAA,KAAS,MAAA,CAAO,KAAK,CAAC,CAAA;AAC1C,IAAA,KAAA,CAAM,IAAA,CAAK,QAAQ,CAAA,IAAA,KAAQ;AACzB,MAAA,IAAI,IAAA,EAAM;AACR,QAAA,MAAA,CAAO,IAAIA,oBAAA,CAAc,IAAA,EAAM,IAAI,CAAC,CAAA;AAAA,MACtC,CAAA,MAAO;AACL,QAAA,OAAA,EAAQ;AAAA,MACV;AAAA,IACF,CAAC,CAAA;AAAA,EACH,CAAC,CAAA;AACH;;;;;;;;"}
