+{"version":3,"file":"ConfigInjectingHtmlWebpackPlugin.cjs.js","sources":["../../../../../src/modules/build/lib/bundler/ConfigInjectingHtmlWebpackPlugin.ts"],"sourcesContent":["/*\n * Copyright 2024 The Backstage Authors\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\nimport { AppConfig } from '@backstage/config';\nimport HtmlWebpackPlugin from 'html-webpack-plugin';\n\nexport class ConfigInjectingHtmlWebpackPlugin extends HtmlWebpackPlugin {\n  readonly name = 'ConfigInjectingHtmlWebpackPlugin';\n  readonly #getFrontendAppConfigs: () => AppConfig[];\n\n  constructor(\n    options: HtmlWebpackPlugin.Options,\n    getFrontendAppConfigs: () => AppConfig[],\n  ) {\n    super(options);\n    this.#getFrontendAppConfigs = getFrontendAppConfigs;\n  }\n\n  apply: HtmlWebpackPlugin['apply'] = compiler => {\n    super.apply(compiler);\n\n    compiler.hooks.compilation.tap(this.name, compilation => {\n      const hooks = HtmlWebpackPlugin.getCompilationHooks(compilation);\n      hooks.alterAssetTagGroups.tap(this.name, ctx => {\n        if (ctx.plugin !== this) {\n          return ctx;\n        }\n        return {\n          ...ctx,\n          headTags: [\n            ...ctx.headTags,\n            HtmlWebpackPlugin.createHtmlTagObject(\n              'script',\n              { type: 'backstage.io/config' },\n              `\\n${JSON.stringify(this.#getFrontendAppConfigs(), null, 2)}\\n`,\n            ),\n          ],\n        };\n      });\n    });\n  };\n}\n"],"names":["HtmlWebpackPlugin"],"mappings":";;;;;;;;AAmBO,MAAM,yCAAyCA,kCAAA,CAAkB;AAAA,EAC7D,IAAA,GAAO,kCAAA;AAAA,EACP,sBAAA;AAAA,EAET,WAAA,CACE,SACA,qBAAA,EACA;AACA,IAAA,KAAA,CAAM,OAAO,CAAA;AACb,IAAA,IAAA,CAAK,sBAAA,GAAyB,qBAAA;AAAA,EAChC;AAAA,EAEA,QAAoC,CAAA,QAAA,KAAY;AAC9C,IAAA,KAAA,CAAM,MAAM,QAAQ,CAAA;AAEpB,IAAA,QAAA,CAAS,KAAA,CAAM,WAAA,CAAY,GAAA,CAAI,IAAA,CAAK,MAAM,CAAA,WAAA,KAAe;AACvD,MAAA,MAAM,KAAA,GAAQA,kCAAA,CAAkB,mBAAA,CAAoB,WAAW,CAAA;AAC/D,MAAA,KAAA,CAAM,mBAAA,CAAoB,GAAA,CAAI,IAAA,CAAK,IAAA,EAAM,CAAA,GAAA,KAAO;AAC9C,QAAA,IAAI,GAAA,CAAI,WAAW,IAAA,EAAM;AACvB,UAAA,OAAO,GAAA;AAAA,QACT;AACA,QAAA,OAAO;AAAA,UACL,GAAG,GAAA;AAAA,UACH,QAAA,EAAU;AAAA,YACR,GAAG,GAAA,CAAI,QAAA;AAAA,YACPA,kCAAA,CAAkB,mBAAA;AAAA,cAChB,QAAA;AAAA,cACA,EAAE,MAAM,qBAAA,EAAsB;AAAA,cAC9B;AAAA,EAAK,KAAK,SAAA,CAAU,IAAA,CAAK,wBAAuB,EAAG,IAAA,EAAM,CAAC,CAAC;AAAA;AAAA;AAC7D;AACF,SACF;AAAA,MACF,CAAC,CAAA;AAAA,IACH,CAAC,CAAA;AAAA,EACH,CAAA;AACF;;;;"}
