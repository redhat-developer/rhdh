{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "dom"],
    "types": ["@playwright/test", "node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@support/*": ["./playwright/support/*"]
    }
  },
  "include": ["**/*.ts"]
}
